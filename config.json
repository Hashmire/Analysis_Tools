{
    "application": {
        "toolname": "Hashmire/Analysis_Tools",
        "version": "0.4.0"
    },
    "cache_settings": {
        "cpe_cache": {
            "filename": "cpe_base_string_cache.json",
            "auto_save_threshold": 50,
            "max_loaded_shards": 16,
            "description": "NVD CPE API responses with per-entry expiration, sharding for better scaling across organizational dataset volume",
            "sharding": {
                "enabled": true,
                "num_shards": 16
            },
            "refresh_strategy": {
                "field_path": "$.*.last_queried",
                "notify_age_hours": 720
            }
        },
        "nvd_source_data": {
            "filename": "nvd_source_data.json",
            "description": "NVD source organization data, derived from the NVD /source/ API",
            "refresh_strategy": {
                "field_path": "$.created_at",
                "notify_age_hours": 168
            }
        },
        "cve_list_v5": {
            "path": "cache/cve_list_v5",
            "description": "CVE List V5 repository with per-file tracking",
            "refresh_strategy": {
                "last_manual_update": "1970-01-01T00:00:00+00:00",
                "notify_age_hours": 720
            }
        },
        "nvd_2_0_cve": {
            "path": "cache/nvd_2.0_cves",
            "description": "NVD CVE 2.0 API responses cache with per-file tracking",
            "refresh_strategy": {
                "field_path": "$.vulnerabilities.*.cve.lastModified"
            }
        },
        "nvd_ish_output": {
            "path": "cache/nvd-ish_2.0_cves",
            "description": "Enhanced NVD 2.0 format records with integrated CVE List V5 data and analysis tool processing outputs"
        },
        "confirmed_mappings": {
            "path": "cache/alias_mappings",
            "description": "Confirmed CPE base string mappings for platform entries"
        }
    },
    "logging": {
        "enabled": true,
        "level": "DEBUG",
        "description": "Log format: [{timestamp}] [{level}] {message}. Available levels (most to least verbose): DEBUG, INFO, WARNING, ERROR.",
        "sdc_report": {
            "progress_interval": 2000
        },
        "alias_report": {
            "progress_interval": 2000
        },
        "cpeas_automation_report": {
            "progress_interval": 2000
        }
    },
    "harvest_and_process_sources": {
        "max_cves_per_source": 30000,
        "quiet_individual": false
    },
    "api": {
        "api_key": "",
        "timeouts": {
            "public_ip": 5,
            "nvd_api": 120,
            "cve_org": 120
        },
        "retry": {
            "max_attempts_nvd": 10,
            "max_attempts_cpe": 10,
            "delay_with_key": 0,
            "delay_without_key": 6,
            "page_delay_with_key": 1,
            "page_delay_without_key": 1
        },
        "endpoints": {
            "public_ip": "https://api.ipify.org",
            "cve_list": "https://cveawg.mitre.org/api/cve/",
            "nvd_cves": "https://services.nvd.nist.gov/rest/json/cves/2.0/",
            "nvd_sources": "https://services.nvd.nist.gov/rest/json/source/2.0/",
            "nvd_cpes": "https://services.nvd.nist.gov/rest/json/cpes/2.0",
            "nvd_cpematch": "https://services.nvd.nist.gov/rest/json/cpematch/2.0"
        },
        "schemas": {
            "nvd_cpes_2_0": "https://csrc.nist.gov/schema/nvd/api/2.0/cpe_api_json_2.0.schema",
            "nvd_cves_2_0": "https://csrc.nist.gov/schema/nvd/api/2.0/cve_api_json_2.0.schema",
            "nvd_source_2_0": "https://csrc.nist.gov/schema/nvd/api/2.0/source_api_json_2.0.schema",
            "cve_cve_5_2": "https://raw.githubusercontent.com/CVEProject/cve-schema/refs/heads/main/schema/docs/CVE_Record_Format_bundled.json"
        }
    }
}
